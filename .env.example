# Copy to .env and tweak. All have sensible defaults; any can be overridden inline.
# NOTE: keep comments on their OWN lines — Docker Compose does not strip inline
# comments after an empty value, so "KEY=  # comment" breaks parsing.

# tiny|base|small|medium|large-v3|large-v3-turbo
MODEL=large-v3

# Devices are INDEPENDENT per stage (cuda|cpu|auto). 'auto' uses the GPU if present.
# Common combos:
#   full-GPU (needs gpu override):   TRANSCRIBE_DEVICE=cuda  DIARIZE_DEVICE=cuda
#   transcribe-GPU + diarize-CPU:    TRANSCRIBE_DEVICE=cuda  DIARIZE_DEVICE=cpu   <- most robust
#   CPU-only:                        TRANSCRIBE_DEVICE=cpu   DIARIZE_DEVICE=cpu
TRANSCRIBE_DEVICE=auto
DIARIZE_DEVICE=auto
# DEVICE is an optional fallback for both if the per-stage vars are unset.

# empty=auto (float16 on cuda, int8 on cpu). Or float16|int8_float16|int8
COMPUTE_TYPE=
# language code, or auto
LANGUAGE=pl
# known speaker count, or 0 = auto-cluster
NUM_SPEAKERS=3
# 1 = run speaker diarization, 0 = transcription only
DIARIZE=1
# pyannote4 = 4.x community-1 on CPU (best quality, default)
# pyannote = 3.x speaker-diarization-3.1 on GPU (fast)
# sherpa = token-free fallback
DIARIZER=pyannote4
# REQUIRED for pyannote / pyannote4. Free: https://huggingface.co/settings/tokens
#   after accepting terms at https://hf.co/pyannote/speaker-diarization-3.1,
#   https://hf.co/pyannote/segmentation-3.0, and (for pyannote4)
#   https://hf.co/pyannote/speaker-diarization-community-1
HF_TOKEN=
# optional: Alice,Bob,Carol  (maps speaker 0,1,2 -> names)
SPEAKER_NAMES=
BEAM_SIZE=5
# filename inside ./input (default: first file found)
INPUT=
